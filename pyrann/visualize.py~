        # same sim mask
        same_sim = (neighbor_sims == global_sim[:, None])

        # deleted status per neighbor — deleted is indexed by sim number (0..N-1)
        nbr_deleted = deleted[neighbor_sims]

        # valid: different sim AND not deleted
        valid = (~same_sim) & (nbr_deleted == 0)

        # for each point, find first valid neighbor
        has_valid = valid.any(axis=1)
        first_valid = np.argmax(valid, axis=1)

        rows = np.arange(n_points)

        # fallback case: no valid neighbor found — use last neighbor, distance += 1
        fallback_idx = k - 1
        nn_dist = np.where(
            has_valid,
            dd[rows, first_valid],
            1 + dd[rows, fallback_idx]   # matches original: nn_dist_list.append(1+dd[i][j])
        )

        # per-sim mean and std using bincount
        # global_sim values are 0..nsims-1, safe to use directly
        counts = np.bincount(global_sim, minlength=nsims).astype(np.float64)
        sum_d  = np.bincount(global_sim, weights=nn_dist,    minlength=nsims)
        sum_d2 = np.bincount(global_sim, weights=nn_dist**2, minlength=nsims)

        mean = sum_d / np.maximum(counts, 1)
        var  = sum_d2 / np.maximum(counts, 1) - mean**2
        std  = np.sqrt(np.maximum(var, 0))

        # metric indexed by position in global_unique, deleted[i] uses sim number as index
        # this matches: [std[i]/mean[i] if deleted[i] == 0 else 10000 for i in range(len(std))]
        # metric = np.where(deleted[global_unique] == 0,
        #                   std[global_unique] / np.maximum(mean[global_unique], 1e-12),
        #                   10000.0)
        metric = np.where(deleted[global_unique] == 0,
                std[global_unique] / mean[global_unique],
                100000.0)

        best_pos   = int(np.argmin(metric))           # position in global_unique
        del_sim_num = int(global_unique[best_pos])    # actual sim number

        # matches: [0 if i != del_sim_num and deleted[i] != 1 else 1 for i in global_unique]
        deleted = np.where(
            (global_unique != del_sim_num) & (deleted[global_unique] != 1),
            0, 1
        ).astype(np.float64)

        print(f'{mwn45 = }; {del_sim_num = }; {min(metric) = }')

    # deleted is now indexed by position in global_unique
    # mask: for i in range(len(deleted)) -> position in global_unique, a[i].inum atoms each
    mask = [deleted[i] == 0 for i in range(len(deleted)) for _ in range(a[i].inum)]
    keep_df = df_original[mask].copy()

    return mask

